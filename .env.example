# ── Hermes environment template ───────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit the real .env.
# The frontend container is started with --env-file ./.env, so every var below is
# available to both the FastAPI backend and the Next.js runtime.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your_postgres_password_here
# Full DSN used by the Next.js pg.Pool (NextAuth login lookups).
DATABASE_URL=postgresql://postgres:your_postgres_password_here@hermes_db:5432/postgres

# ── AI / email / data providers ────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here
RESEND_API_KEY=your_resend_api_key_here
SAM_API_KEY=your_sam_gov_api_key_here

# ── Backend trust secrets (ENTERPRISE_AUDIT P0-3) ──────────────────────────────
# These MUST be three independent, high-entropy random values in production.
# Generate each with:  openssl rand -hex 32
# If GATEWAY/VENDOR are unset they fall back to BACKEND_ADMIN_TOKEN (single-secret
# mode) so the app still boots — but that is exactly the conflation the audit flags.
BACKEND_ADMIN_TOKEN=your_admin_api_token_here           # admin proxy -> backend
BACKEND_GATEWAY_TOKEN=your_gateway_token_here           # any proxy -> backend (came-via-proxy proof)
BACKEND_VENDOR_SIGNING_KEY=your_vendor_signing_key_here # HMAC key binding vendor_id

# ── Auth (NextAuth + admin) ────────────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_jwt_signing_secret_here
NEXTAUTH_URL=https://www.burgergov.com
ADMIN_EMAIL=procurement@burgergov.com
# Admin credential is a bcrypt hash in the DB (P1-3). For the legacy/bootstrap path,
# ADMIN_PASSWORD (plaintext) is still honored if set, but should be left UNSET once the
# hashed admin row exists. Never reuse NEXTAUTH_SECRET as the admin password.
# ADMIN_PASSWORD=

# ── Service URLs ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://www.burgergov.com
INTERNAL_API_URL=http://hermes_backend:8000
DB_HOST=hermes_db

# ── Business identifiers ───────────────────────────────────────────────────────
CAGE_CODE=PENDING
SAM_STATUS=REGISTRATION_IN_PROGRESS
